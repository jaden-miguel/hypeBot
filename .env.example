# =============================================================
# HypeBot Environment Variables
# Copy this file to .env and fill in your values
# =============================================================

# Ollama
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1

# Open WebUI (your existing container on port 3000)
OPENWEBUI_HOST=http://host.docker.internal:3000

# Scrape interval in seconds (default 300 = 5 minutes)
SCRAPE_INTERVAL=300

# Discord webhook (leave empty to disable)
DISCORD_WEBHOOK_URL=

# Email alerts (leave empty to disable)
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
